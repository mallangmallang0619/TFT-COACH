# ─── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/

# Vite cache lives inside node_modules but call it out explicitly in case it
# ever moves:
.vite/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Python / Backend ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / type-checking caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Packaging artifacts
build/
dist/
*.egg-info/
*.egg

# ─── Electron build output ────────────────────────────────────────────────────
dist-electron/
out/

# ─── App-generated runtime data ───────────────────────────────────────────────
# Annotated frame dumps written by detector.py when LOG_DETECTION_FRAMES=True
debug_frames/

# Captured templates can be huge and are user-specific (per resolution / patch).
# The .gitkeep files in each subdir keep the directory layout in version control.
assets/templates/components/*
assets/templates/champions/*
assets/templates/ui/*
!assets/templates/**/.gitkeep

# Cache of TFT Academy tier list — regenerated by tftacademy_live.py on first
# run. Comment this out if you want a versioned baseline cache shipped in the
# repo (the `init_from_cache()` call falls back to META_COMPS in game_data.py
# either way).
# assets/tftacademy_cache.json

# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.\#*
\#*\#

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
.cache/
